---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BASE_URL, REPO, BETA_CONTACT_EMAIL } from "../consts";
---

<BaseLayout
  title="Join the closed beta - Compass"
  description="Sign up for the Compass closed beta. Early access to the commercial hosted tier with bundled inference, priority support, and enterprise features."
  canonical={`${BASE_URL}/beta`}
>
  <section class="page-hero" style="text-align:center">
    <div class="container container-narrow">
      <p class="section-kicker reveal">Closed beta</p>
      <h1 class="reveal">Join the waitlist</h1>
      <p class="reveal" style="font-size:1.05rem;color:var(--text-dim);max-width:560px;margin:0 auto;line-height:1.7">
        Compass is open source and free to use. The closed beta gives you early access to the upcoming
        commercial hosted tier - bundled inference, priority updates, and enterprise features.
      </p>
    </div>
  </section>

  <section class="section section-alt" style="padding-top:0">
    <div class="container container-narrow">
      <div class="glass" style="padding:40px;text-align:center">
        <form
          id="beta-form"
          class="reveal"
          data-repo={REPO}
          style="display:flex;flex-direction:column;gap:16px;max-width:440px;margin:0 auto"
        >
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="form-input"
            aria-label="Email address"
          />
          <input type="text" name="name" placeholder="Your name (optional)" class="form-input" aria-label="Your name" />
          <textarea
            name="message"
            placeholder="Anything you'd like us to know? (optional)"
            rows="3"
            class="form-input"
            aria-label="Message"
            style="font-family:var(--font-sans);resize:vertical"
          ></textarea>
          <button type="submit" class="btn btn-primary" style="justify-content:center;width:100%">
            Join the closed beta
          </button>
          <p style="font-size:.8rem;color:var(--text-faint)">
            No spam. Submitting opens a pre-filled GitHub issue so we can follow up when beta slots open. Your email is never shared.
          </p>
          {BETA_CONTACT_EMAIL && (
            <p style="font-size:.8rem;color:var(--text-faint)">
              Prefer email? <a href={`mailto:${BETA_CONTACT_EMAIL}?subject=${encodeURIComponent("Compass beta signup")}`}>Email us directly</a>.
            </p>
          )}
          <div class="form-status" id="form-status"></div>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-narrow">
      <h2 class="reveal" style="font-size:1.3rem;margin-bottom:24px;font-weight:600">Frequently asked questions</h2>
      <div style="display:flex;flex-direction:column;gap:24px">
        <div class="reveal">
          <h3 style="font-size:.95rem;margin-bottom:4px;color:var(--text)">What does the closed beta include?</h3>
          <p style="font-size:.88rem;color:var(--text-dim)">Early access to the commercial hosted tier - bundled inference (no separate API keys needed), priority support, early feature access (remote sessions, multi-file orchestration, project memory), and a say in the roadmap.</p>
        </div>
        <div class="reveal">
          <h3 style="font-size:.95rem;margin-bottom:4px;color:var(--text)">Is Compass still open source?</h3>
          <p style="font-size:.88rem;color:var(--text-dim)">Yes. The core IDE remains open source under the MIT license. The beta enrolls you in the <strong>commercial hosted tier</strong> - a paid service that bundles inference, removes the need to manage your own API keys, and adds enterprise features.</p>
        </div>
        <div class="reveal">
          <h3 style="font-size:.95rem;margin-bottom:4px;color:var(--text)">How much will it cost?</h3>
          <p style="font-size:.88rem;color:var(--text-dim)">Pricing TBD. We're exploring a usage-based model - not per-seat. Local AI stays free. You only pay for cloud inference and managed features. Beta participants will get a discounted founder rate.</p>
        </div>
        <div class="reveal">
          <h3 style="font-size:.95rem;margin-bottom:4px;color:var(--text)">Do I need Apple Silicon?</h3>
          <p style="font-size:.88rem;color:var(--text-dim)">Yes. Compass requires an Apple Silicon Mac running macOS 26+. The local pipeline uses MLX, the Metal-backed framework designed for Apple's unified memory architecture.</p>
        </div>
        <div class="reveal">
          <h3 style="font-size:.95rem;margin-bottom:4px;color:var(--text)">Can I just use the open source build?</h3>
          <p style="font-size:.88rem;color:var(--text-dim)">Absolutely. Download the latest build from GitHub Releases. You'll need your own API keys for cloud models, but local completion and Q&A work completely offline and free.</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById("beta-form");
    const status = document.getElementById("form-status");
    if (form) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const email = (form.elements.email.value || "").trim();
        const name = (form.elements.name.value || "").trim();
        const message = (form.elements.message.value || "").trim();
        if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
          status.textContent = "⚠️ Please enter a valid email so we can reach you.";
          status.className = "form-status error";
          form.elements.email.focus();
          return;
        }
        const repo = form.dataset.repo || "https://github.com/jtrefon/ai-ide";
        const title = encodeURIComponent(`Beta signup — ${email}`);
        const body = encodeURIComponent(
          `**Email:** ${email}\n**Name:** ${name || "—"}\n\n${message || "Excited to try Compass!"}\n\n_Submitted from the Compass website._`
        );
        const url = `${repo}/issues/new?title=${title}&body=${body}&labels=beta`;
        status.textContent = "✅ Opening GitHub to complete your signup…";
        status.className = "form-status success";
        form.reset();
        const win = window.open(url, "_blank", "noopener");
        if (!win) {
          status.textContent =
            "✅ Signup ready — if the tab didn't open, visit the Issues tab on GitHub and we'll be in touch.";
          status.className = "form-status success";
        }
      });
    }
  </script>
</BaseLayout>
