---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  eager?: boolean;
}
const { src, alt, caption, width, height, eager = false } = Astro.props;
---

<figure class="product-shot reveal">
  <div class="product-frame">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
    />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>
