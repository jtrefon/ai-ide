---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BASE_URL, REPO } from "../consts";
---

<BaseLayout
  title="Contributors - osx-ide"
  description="Build the future of native macOS AI development. osx-ide is open source - contribute to Swift, MLX, or tooling."
  canonical={`${BASE_URL}/contributors`}
>
  <section class="page-hero" style="text-align:center">
    <div class="container container-narrow">
      <p class="section-kicker reveal">Open source</p>
      <h1 class="reveal">For contributors</h1>
      <p class="reveal" style="font-size:1.05rem;color:var(--text-dim);max-width:560px;margin:0 auto;line-height:1.7">
        osx-ide is MIT-licensed and built entirely in Swift. If you want to shape how native AI development works on macOS, this is the place.
      </p>
      <div class="reveal" style="margin-top:20px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a class="btn btn-primary" href={`${REPO}/blob/main/CONTRIBUTING.md`} target="_blank" rel="noreferrer">Contribution guide</a>
        <a class="btn btn-secondary" href={`${REPO}/issues`} target="_blank" rel="noreferrer">Open issues</a>
        <a class="btn btn-secondary" href={REPO} target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </div>
  </section>

  <section class="section section-alt" style="padding-top:0">
    <div class="container container-narrow">
      <div class="grid-2" style="gap:24px">
        <div class="card reveal">
          <h3 style="font-size:1rem;margin-bottom:8px;color:var(--cyan)">Codebase</h3>
          <p style="font-size:.88rem;color:var(--text-dim);line-height:1.7">
            ~40,000 lines of Swift across <code>osx-ide/</code>, the test harness, and the UI layer.
            Build with Xcode 26+ and Apple Silicon. The project uses <code>xcodebuild</code> (not SwiftPM) for the main target,
            with SPM packages for <code>SyntaxHighlighting</code> (tree-sitter) and <code>Terminal</code>.
          </p>
          <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap">
            <span class="badge badge-live">SwiftUI</span>
            <span class="badge badge-live">AppKit</span>
            <span class="badge badge-live">MLX</span>
            <span class="badge badge-live">FAISS</span>
            <span class="badge badge-live">SQLite</span>
            <span class="badge badge-live">Tree-sitter</span>
          </div>
        </div>
        <div class="card reveal">
          <h3 style="font-size:1rem;margin-bottom:8px;color:var(--violet)">Get started</h3>
          <pre style="font-family:var(--font-mono);font-size:.82rem;background:var(--bg);padding:16px;border-radius:8px;overflow-x:auto;color:var(--text-dim);line-height:1.8">./run.sh build
./run.sh test
./run.sh harness
xcodebuild test -scheme osx-ide</pre>
          <p style="font-size:.85rem;color:var(--text-faint);margin-top:8px">
            See <code>AGENTS.md</code> and <code>ARCHITECTURE.md</code> in the repo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-narrow">
      <h2 class="reveal" style="font-size:1.3rem;margin-bottom:20px;font-weight:600">Where to start</h2>
      <div style="display:flex;flex-direction:column;gap:16px">
        <div class="reveal card">
          <h3 style="font-size:.95rem;margin-bottom:4px">Two-pipeline isolation</h3>
          <p style="font-size:.85rem;color:var(--text-dim)">The core architecture: local (4B MLX, no orchestration) and cloud (orchestration graph, 20+ tools). They share zero AI execution code.</p>
          <code style="margin-top:8px;display:inline-block">Services/LocalPipeline/ · Services/CloudPipeline/</code>
        </div>
        <div class="reveal card">
          <h3 style="font-size:.95rem;margin-bottom:4px">Codebase index</h3>
          <p style="font-size:.85rem;color:var(--text-dim)">SQLite FTS5 engine for symbols, chunks, files, and HNSW-backed embedding retrieval. All in <code>Services/Index/</code>.</p>
          <code style="margin-top:8px;display:inline-block">Services/Index/DatabaseManager.swift</code>
        </div>
        <div class="reveal card">
          <h3 style="font-size:.95rem;margin-bottom:4px">Inline completion engine</h3>
          <p style="font-size:.85rem;color:var(--text-dim)">Local FIM completion with ghost-text rendering, caching, ranking, and sub-100ms latency. The tightest latency loop in the app.</p>
          <code style="margin-top:8px;display:inline-block">Services/LocalPipeline/InlineCompletionEngine.swift</code>
        </div>
        <div class="reveal card">
          <h3 style="font-size:.95rem;margin-bottom:4px">Agent tool system</h3>
          <p style="font-size:.85rem;color:var(--text-dim)">20+ tools implementing the <code>AITool</code> protocol. The tool loop runs in <code>ToolLoopHandler.swift</code> with stall detection.</p>
          <code style="margin-top:8px;display:inline-block">Services/Tools/ · Services/CloudPipeline/ToolLoopHandler.swift</code>
        </div>
      </div>
      <div class="reveal" style="margin-top:32px;text-align:center">
        <p style="color:var(--text-dim)">
          For full architecture docs, read <a href={`${REPO}/blob/main/ARCHITECTURE.md`} style="color:var(--accent);text-decoration:underline">ARCHITECTURE.md</a>
          and <a href={`${REPO}/blob/main/FEATURES.md`} style="color:var(--accent);text-decoration:underline">FEATURES.md</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
