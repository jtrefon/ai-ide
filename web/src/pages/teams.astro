---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BASE_URL, RELEASES } from "../consts";
---

<BaseLayout
  title="For teams & companies - Compass"
  description="Compass gives teams real AI coding without shipping source code to a vendor. Compliance by design, usage-based pricing, and on-device RAG that keeps institutional knowledge in-house."
  canonical={`${BASE_URL}/teams`}
>
  <section class="page-hero">
    <div class="container container-narrow">
      <p class="section-kicker reveal">For teams &amp; companies</p>
      <h1 class="reveal">Ship faster without shipping your source code to a vendor.</h1>
      <p class="reveal" style="font-size:1.05rem;color:var(--text-dim);max-width:620px;line-height:1.7">
        Compass puts real AI in every developer's editor while keeping your IP on the endpoint. Local AI is
        free; cloud is opt-in and usage-based — not per-seat.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2" style="gap:40px">
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Compliance by design</h3>
          <p style="font-size:.92rem;color:var(--text-dim);line-height:1.7">
            IP never leaves the endpoint without explicit consent. Privacy isn't a policy checkbox bolted on later —
            it's the architecture. That clears procurement and security reviews that cloud-only editors fail.
          </p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Usage-based, not per-seat</h3>
          <p style="font-size:.92rem;color:var(--text-dim);line-height:1.7">
            Daily coding is local and free. Cloud inference is only paid for when a task actually needs it.
            No $15–20/mo per seat just to autocomplete.
          </p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Knowledge stays in-house</h3>
          <p style="font-size:.92rem;color:var(--text-dim);line-height:1.7">
            On-device RAG embeds your entire codebase and work history. Institutional knowledge compounds locally —
            no copy of your repo ever lands in a third-party model's training set.
          </p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Happier, faster engineers</h3>
          <p style="font-size:.92rem;color:var(--text-dim);line-height:1.7">
            A 200&nbsp;MB native binary on Apple Silicon means longer battery, less thermal throttling, and an editor
            that keeps up with thought. Productivity without the Electron tax.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-kicker reveal">Why teams switch</p>
      <h2 class="section-title reveal">The AI editor your security team will approve.</h2>
      <div class="model-stat reveal" style="margin-top:20px">
        <span class="badge-strong">0</span>
        <p>Bytes of your source code required to leave the endpoint for local AI to work. None. Zero. Nada.</p>
      </div>
    </div>
  </section>

  <section class="section section-alt" style="text-align:center">
    <div class="container container-narrow">
      <h2 class="section-title reveal">Bring Compass to your team.</h2>
      <p class="section-sub reveal" style="margin:0 auto 28px">
        Start with the open-source build, or talk to us about the hosted tier and enterprise features.
      </p>
      <div class="reveal" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a class="btn btn-primary" href={`${BASE_URL}/beta`}>Join the beta</a>
        <a class="btn btn-secondary" href={`${BASE_URL}/enterprise`}>Enterprise &amp; privacy</a>
        <a class="btn btn-secondary" href={RELEASES} target="_blank" rel="noreferrer">Download</a>
      </div>
    </div>
  </section>
</BaseLayout>
