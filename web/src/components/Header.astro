---
import { NAV, REPO, BASE_URL } from "../consts";
---

<header class="site-header">
  <a class="brand" href={`${BASE_URL}/`} aria-label="osx-ide home">
    <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <rect x="2" y="2" width="28" height="28" rx="6" stroke="#c4943e" stroke-width="2.5" fill="none" />
      <path d="M12 20l4-8 4 8" stroke="#c4943e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span>osx-ide</span>
  </a>

  <nav class="topnav" aria-label="Primary navigation">
    {NAV.map((item) =>
      item.href.startsWith("http") ? (
        <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
      ) : (
        <a href={BASE_URL + (item.href === "/" ? "/" : item.href)}>{item.label}</a>
      )
    )}
    <a href={REPO} target="_blank" rel="noreferrer" class="btn btn-secondary" style="padding:6px 14px;margin-left:4px;font-size:.8rem">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      Source
    </a>
  </nav>

  <button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <div class="mobile-menu" id="mobile-menu">
    {NAV.map((item) =>
      item.href.startsWith("http") ? (
        <a href={item.href} class="mobile-link" target="_blank" rel="noreferrer">{item.label}</a>
      ) : (
        <a href={BASE_URL + (item.href === "/" ? "/" : item.href)} class="mobile-link">{item.label}</a>
      )
    )}
    <a href={REPO} class="mobile-link" target="_blank" rel="noreferrer">GitHub</a>
  </div>
</header>
