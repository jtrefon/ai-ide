---
export interface Props {
  width?: number;
  height?: number;
}
const { width = 760, height = 480 } = Astro.props;
---

<svg width={width} height={height} viewBox="0 0 760 480" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Compass architecture diagram">
  <defs>
    <filter id="g">
      <feGaussianBlur stdDeviation="1" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>
    <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10" fill="#8a785e"/>
    </marker>
  </defs>

  <!-- Background -->
  <rect x="0" y="0" width="760" height="480" rx="12" fill="rgba(255,255,255,.03)" stroke="rgba(255,255,255,.07)" stroke-width="1"/>

  <!-- UI Layer -->
  <rect x="80" y="20" width="600" height="60" rx="8" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.1)" stroke-width="1" filter="url(#g)"/>
  <text x="380" y="38" text-anchor="middle" fill="#c4943e" font-family="'JetBrains Mono',monospace" font-size="9" font-weight="600" letter-spacing="2">UI LAYER</text>
  <text x="380" y="65" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="11">SwiftUI Views - AppKit Components - NSTextView - Terminal - Panels</text>

  <!-- Arrow down -->
  <line x1="380" y1="80" x2="380" y2="106" stroke="#8a785e" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- Core Layer -->
  <rect x="80" y="110" width="600" height="50" rx="8" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.1)" stroke-width="1" filter="url(#g)"/>
  <text x="380" y="128" text-anchor="middle" fill="#c4943e" font-family="'JetBrains Mono',monospace" font-size="9" font-weight="600" letter-spacing="2">CORE LAYER</text>
  <text x="380" y="148" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="11">EventBus - CommandRegistry - DependencyContainer - Models</text>

  <!-- Arrow down -->
  <line x1="380" y1="160" x2="380" y2="186" stroke="#8a785e" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- Shared Services -->
  <rect x="80" y="190" width="600" height="50" rx="8" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.1)" stroke-width="1" filter="url(#g)"/>
  <text x="380" y="208" text-anchor="middle" fill="#c4943e" font-family="'JetBrains Mono',monospace" font-size="9" font-weight="600" letter-spacing="2">SHARED SERVICES</text>
  <text x="380" y="228" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="11">CodebaseIndex (SQLite + FTS5 + HNSW) - Tool Impls - FileSystem - Terminal</text>

  <!-- Split arrows -->
  <line x1="220" y1="240" x2="220" y2="270" stroke="#8a785e" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="540" y1="240" x2="540" y2="270" stroke="#8a785e" stroke-width="1.5" marker-end="url(#arrow)"/>

  <text x="380" y="260" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="10">reads context from</text>

  <!-- Local Pipeline -->
  <rect x="60" y="275" width="310" height="185" rx="10" fill="rgba(196,148,62,.04)" stroke="#c4943e" stroke-width=".8" stroke-dasharray="4,3"/>
  <text x="215" y="298" text-anchor="middle" fill="#c4943e" font-family="'JetBrains Mono',monospace" font-size="10" font-weight="600" letter-spacing="1.5">LOCAL PIPELINE</text>
  <text x="215" y="314" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10">Always on - offline - &lt;100ms</text>

  <!-- Local components -->
  <rect x="90" y="330" width="128" height="44" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="154" y="350" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Local Interaction</text>
  <text x="154" y="365" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">Direct LLM - no orchestration</text>

  <rect x="230" y="330" width="128" height="44" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="294" y="348" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Inline Completion</text>
  <text x="294" y="365" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">Ghost text - cache - rank</text>

  <rect x="90" y="388" width="128" height="44" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="154" y="408" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Inline Popover</text>
  <text x="154" y="423" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">Cursor-anchored Q&amp;A</text>

  <rect x="230" y="388" width="128" height="44" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="294" y="408" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Semantic Search</text>
  <text x="294" y="423" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">HNSW ANN - CoreML</text>

  <!-- Cloud Pipeline -->
  <rect x="390" y="275" width="310" height="185" rx="10" fill="rgba(255,255,255,.03)" stroke="rgba(255,255,255,.12)" stroke-width=".8" stroke-dasharray="4,3"/>
  <text x="545" y="298" text-anchor="middle" fill="#bba586" font-family="'JetBrains Mono',monospace" font-size="10" font-weight="600" letter-spacing="1.5">CLOUD PIPELINE</text>
  <text x="545" y="314" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10">On demand - opt-in - remote models</text>

  <!-- Cloud components -->
  <rect x="540" y="330" width="128" height="58" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="604" y="350" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Conversation</text>
  <text x="604" y="362" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Orchestrator</text>
  <text x="604" y="380" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">Planner > Worker > QA > Final</text>

  <rect x="410" y="330" width="118" height="58" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="469" y="350" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Tool Loop</text>
  <text x="469" y="362" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">20+ AITool impls</text>
  <text x="469" y="380" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">Stall detection</text>

  <rect x="410" y="400" width="118" height="36" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="469" y="416" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">RAG Engine</text>
  <text x="469" y="429" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">Retrieval + ranking</text>

  <rect x="540" y="400" width="128" height="36" rx="6" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.08)" stroke-width=".8"/>
  <text x="604" y="416" text-anchor="middle" fill="#bba586" font-family="'Inter',sans-serif" font-size="10" font-weight="600">Tool Executor</text>
  <text x="604" y="429" text-anchor="middle" fill="#8a785e" font-family="'Inter',sans-serif" font-size="9">File I/O, terminal, search</text>
</svg>
