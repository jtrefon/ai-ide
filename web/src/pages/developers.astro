---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductShot from "../components/ProductShot.astro";
import { BASE_URL, REPO, RELEASES } from "../consts";
---

<BaseLayout
  title="For developers - Compass"
  description="Compass is the native macOS AI IDE developers actually want: a 200MB Swift binary, real on-device FIM from a 1.5B model, Apple Neural Engine RAG, and zero Electron bloat."
  canonical={`${BASE_URL}/developers`}
>
  <section class="page-hero">
    <div class="container container-narrow">
      <p class="section-kicker reveal">For developers</p>
      <h1 class="reveal">The editor that finally feels like macOS.</h1>
      <p class="reveal" style="font-size:1.05rem;color:var(--text-dim);max-width:620px;line-height:1.7">
        Compass is a Swift-native IDE with real AI built in — completion, retrieval, and agentic coding that
        run on your Apple Silicon. No Electron. No JavaScript bloat. No code shipped to the cloud.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2" style="align-items:center;gap:40px">
        <div class="reveal">
          <p class="section-kicker">Real AI, on your machine</p>
          <h2 class="section-title" style="font-size:clamp(1.5rem,3vw,2.1rem)">Completion that's actually intelligent.</h2>
          <p style="color:var(--text-dim);line-height:1.75;margin-top:12px">
            Ghost-text completion in <strong>&lt;100ms</strong> from a <strong>1.5B on-device model</strong> — genuine
            intelligence, not a fake heuristic. Retrieval runs on the <strong>Apple Neural Engine</strong>, so indexing
            and search stay silent and painless while you keep typing.
          </p>
          <p style="color:var(--text-dim);line-height:1.75;margin-top:12px">
            Offline? Still works. Plane, tunnel, coffee shop — your AI doesn't quit because it never needed the network.
          </p>
        </div>
        <div class="reveal">
          <ProductShot
            src={`${BASE_URL}/images/shot-completion.webp`}
            alt="Inline ghost-text completion appearing as you type in Compass"
            width={856}
            height={336}
            caption="Sub-100ms ghost-text completion from the on-device model."
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-kicker reveal">Native to the core</p>
      <h2 class="section-title reveal">Built for the silicon it runs on.</h2>
      <div class="grid-3" style="margin-top:28px">
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">~200 MB. AI included.</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">The whole app — every AI capability on — fits in roughly 200&nbsp;MB. Smaller than most editors with AI turned off.</p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">No Electron tax</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">A real macOS binary in Swift. No Chromium, no event loop burning your CPU, no gigabytes of JavaScript in RAM.</p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Liquid Glass &amp; deep OS access</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">Full low-level Apple OS features, including the latest Liquid Glass framework — something a web wrapper can never touch.</p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Built-in browser</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">Read docs and references without leaving the editor. One app, zero context-switching to a browser.</p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Built-in local inference</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">MLX-backed models run chat, quick actions, and agentic work on your Mac. Offline. Private. No API key required.</p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Bring your own model</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">Route heavy work through OpenRouter, DeepSeek, Alibaba, or Kilo today — Anthropic &amp; OpenAI support lands next iteration.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt" style="text-align:center">
    <div class="container container-narrow">
      <h2 class="section-title reveal">Build with Compass.</h2>
      <p class="section-sub reveal" style="margin:0 auto 28px">
        Open source and free. Requires Apple Silicon and macOS 26+.
      </p>
      <div class="reveal" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a class="btn btn-primary" href={RELEASES} target="_blank" rel="noreferrer">Download latest</a>
        <a class="btn btn-secondary" href={`${BASE_URL}/beta`}>Join the beta</a>
        <a class="btn btn-secondary" href={REPO} target="_blank" rel="noreferrer">View source</a>
      </div>
    </div>
  </section>
</BaseLayout>
