---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductShot from "../components/ProductShot.astro";
import { BASE_URL } from "../consts";

const FAQ = [
  {
    q: "Does Compass send my code to the cloud?",
    a: "For local AI, no. Completion, retrieval (RAG), and agentic work run entirely on your Mac using on-device models and the Apple Neural Engine. Nothing is required to leave the endpoint. Cloud models are strictly opt-in.",
  },
  {
    q: "Can Compass run fully air-gapped?",
    a: "Yes. Because inference, embeddings, and retrieval all execute on-device, Compass works with no network connection at all, ideal for classified, regulated, or offline environments.",
  },
  {
    q: "Is Compass open source and auditable?",
    a: "Yes. The core IDE is open source, so security and compliance teams can audit exactly what the binary does. There is no opaque telemetry exfiltration of your code.",
  },
  {
    q: "Which industries is Compass suited to?",
    a: "Any organization where data residency is non-negotiable: defense and government, financial services, healthcare, and IP-heavy research and engineering teams.",
  },
];
---

<BaseLayout
  title="Enterprise & privacy - Compass"
  description="Compass is the only AI IDE you can deploy where data cannot leave the building. Total privacy by architecture: air-gapped capable, zero network egress, open source and auditable."
  canonical={`${BASE_URL}/enterprise`}
>
  <section class="page-hero">
    <div class="container container-narrow">
      <p class="section-kicker reveal">Enterprise &amp; privacy</p>
      <h1 class="reveal">The AI IDE for the work that can't leave the building.</h1>
      <p class="reveal" style="font-size:1.05rem;color:var(--text-dim);max-width:640px;line-height:1.7">
        Compass isn't private by policy, it's private by architecture. Every suggestion, retrieval, and agent
        step stays on the endpoint. Nothing egresses. No vendor sits in your supply chain.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2" style="align-items:center;gap:40px">
        <div class="reveal">
          <ProductShot
            src={`${BASE_URL}/images/shot-ide.webp`}
            alt="Compass IDE running natively on macOS with the agentic chat panel"
            width={1473}
            height={1039}
            caption="The full IDE, running entirely on-device."
          />
        </div>
        <div>
          <p class="section-kicker reveal">Total privacy by architecture</p>
          <h2 class="section-title reveal" style="font-size:clamp(1.5rem,3vw,2.1rem)">Zero bytes required to leave.</h2>
          <ul style="list-style:none;color:var(--text-dim);line-height:1.9;margin-top:12px" class="reveal">
            <li style="padding:4px 0">✧ <strong>Air-gapped capable</strong>, works with no network at all</li>
            <li style="padding:4px 0">✧ <strong>Zero network egress</strong> for local AI, no telemetry of your code</li>
            <li style="padding:4px 0">✧ <strong>On-device RAG</strong>, embeddings on the Apple Neural Engine</li>
            <li style="padding:4px 0">✧ <strong>Open source &amp; auditable</strong>, inspect the binary yourself</li>
            <li style="padding:4px 0">✧ <strong>No third-party model vendor</strong> in your supply chain</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-kicker reveal">Who it's for</p>
      <h2 class="section-title reveal">Built for the bars others can't clear.</h2>
      <div class="grid-3" style="margin-top:28px">
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Defense &amp; government</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">Air-gapped, on-device AI that meets classification and data-residency requirements cloud editors simply fail.</p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Financial services</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">Keep proprietary trading, risk, and client code on the endpoint. Audit the binary. Satisfy procurement.</p>
        </div>
        <div class="card reveal">
          <h3 style="color:var(--accent);margin-bottom:8px">Healthcare &amp; research</h3>
          <p style="font-size:.9rem;color:var(--text-dim)">PHI and sensitive research stay local. AI assistance without expanding your compliance surface.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container container-narrow">
      <p class="section-kicker reveal">FAQ</p>
      <h2 class="section-title reveal">Privacy, answered.</h2>
      <div style="margin-top:24px;display:flex;flex-direction:column;gap:16px">
        {FAQ.map((item) => (
          <div class="card reveal" style="padding:20px 24px">
            <h3 style="font-size:1rem;margin-bottom:6px;color:var(--text)">{item.q}</h3>
            <p style="font-size:.9rem;color:var(--text-dim);line-height:1.7">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="text-align:center">
    <div class="container container-narrow">
      <h2 class="section-title reveal">Talk to us about your requirements.</h2>
      <p class="section-sub reveal" style="margin:0 auto 28px">
        The closed beta includes early access to the commercial hosted tier with enterprise features.
      </p>
      <div class="reveal" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a class="btn btn-primary" href={`${BASE_URL}/beta`}>Join the beta</a>
        <a class="btn btn-secondary" href={`${BASE_URL}/teams`}>For teams</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: FAQ.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    })),
  })}></script>
</BaseLayout>
